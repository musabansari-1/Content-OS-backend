DATABASE_URL=postgresql://contentos:contentos@localhost:5432/contentos
GROQ_API_KEY=your_groq_api_key
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
TRANSCRIPTYT_API_KEY=your_transcriptyt_api_key
TRANSCRIPTYT_API_URL=https://api.transcriptyt.com/api/v1/transcript
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
UPTIMEROBOT_URL=https://your-uptimerobot-origin.example
PUBLIC_BASE_URL=http://localhost:8000

# Social integrations
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback
X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret
X_REDIRECT_URI=http://localhost:8000/auth/x/callback
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_REDIRECT_URI=http://localhost:8000/auth/instagram/callback

# Optional: use one of these when YouTube blocks anonymous audio downloads.
# On Render, prefer YTDLP_COOKIES_FILE because cookies-from-browser usually won't find a local Chrome profile.
# Export a cookies.txt file in Netscape format and point yt-dlp at it:
# YTDLP_COOKIES_FILE=C:\path\to\cookies.txt
#
# Or let yt-dlp read cookies directly from a browser profile:
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES_FROM_BROWSER=firefox,default
#
# Optional: send a browser-like user agent to yt-dlp.
# YTDLP_USER_AGENT=Mozilla/5.0 ...
